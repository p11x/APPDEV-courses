# Example13.py
# Topic: Keyword-Only Parameters (*)

# This file demonstrates keyword-only parameters in Python.
# Parameters after * must be passed as keywords, not positionally.


# Simple function with keyword-only parameters
def greet(*, name, greeting="Hello") -> None:
    print(greeting + ", " + name + "!")

greet(name="Alice")
greet(name="Bob", greeting="Hi")


# Parameters after * must be passed by keyword
def create_user(*, name, age, city="Unknown") -> None:
    print("Name: " + name + ", Age: " + str(age) + ", City: " + city)

create_user(name="Alice", age=25)
create_user(name="Bob", age=30, city="NYC")


# Mix regular parameters with keyword-only
def func(a, b, *, c, d) -> None:
    print("a=" + str(a) + ", b=" + str(b) + ", c=" + str(c) + ", d=" + str(d))

func(1, 2, c=3, d=4)


# Using * without args to make all params keyword-only
def required_kwargs(*, name, email, role) -> None:
    print("Name: " + name)
    print("Email: " + email)
    print("Role: " + role)

required_kwargs(name="John", email="john@example.com", role="admin")


# Keyword-only with defaults
def configure(*, host="localhost", port=8080, ssl=False) -> None:
    protocol = "https" if ssl else "http"
    print(protocol + "://" + host + ":" + str(port))

configure()
configure(port=3000)
configure(host="api.example.com", ssl=True)


# Using with **kwargs
def process(*, debug=False, **options) -> None:
    print("Debug: " + str(debug))
    print("Options: " + str(options))

process()
process(debug=True, timeout=30, retries=3)


# Forces readable function calls
def send_email(*, to, subject, body, from_addr="noreply@company.com") -> None:
    print("To: " + to)
    print("Subject: " + subject)
    print("Body: " + body)
    print("From: " + from_addr)

send_email(to="user@example.com", subject="Hello", body="Message")


# Keyword-only for configuration
def database_connect(*, host, port, database, user, password) -> str:
    return "Connecting to " + database + " on " + host + ":" + str(port)

conn = database_connect(host="localhost", port=5432, database="mydb", user="admin", password="secret")
print(conn)


# Prevents accidental parameter swapping
def calculate(*, x, y, operation) -> int:
    if operation == "add":
        return x + y
    elif operation == "subtract":
        return x - y
    return 0

result = calculate(x=10, y=5, operation="add")
print("Result: " + str(result))


# Combining *args and keyword-only
def flexible_func(a, *args, keyword_only, **kwargs) -> None:
    print("a=" + str(a))
    print("args=" + str(args))
    print("keyword_only=" + str(keyword_only))
    print("kwargs=" + str(kwargs))

flexible_func(1, 2, 3, 4, keyword_only="value", extra="data")


# Function with all keyword-only after *
def full_kwonly(*, req1, req2, opt1="default", opt2=10) -> None:
    print("req1=" + req1 + ", req2=" + req2 + ", opt1=" + opt1 + ", opt2=" + str(opt2))

full_kwonly(req1="a", req2="b")
full_kwonly(req1="x", req2="y", opt1="custom", opt2=20)


# API endpoint definition style
def define_route(path, *, method="GET", auth_required=True, rate_limit=100) -> None:
    print("Path: " + path)
    print("Method: " + method)
    print("Auth: " + str(auth_required))
    print("Rate limit: " + str(rate_limit))

define_route("/api/users")
define_route("/api/login", method="POST", auth_required=False)


# Ensures clarity in function calls
def draw_shape(*, shape, x=0, y=0, color="black", size=10) -> None:
    print("Drawing " + shape + " at (" + str(x) + "," + str(y) + ")")
    print("Color: " + color + ", Size: " + str(size))

draw_shape(shape="circle", x=10, y=20)
draw_shape(shape="square", color="red", size=5)


# Database query with keyword-only params
def query_db(*, table, where=None, order_by=None, limit=None) -> str:
    sql = "SELECT * FROM " + table
    
    if where:
        sql = sql + " WHERE " + where
    if order_by:
        sql = sql + " ORDER BY " + order_by
    if limit:
        sql = sql + " LIMIT " + str(limit)
    
    return sql

query = query_db(table="users", where="age > 18", order_by="name", limit=10)
print("Query: " + query)
