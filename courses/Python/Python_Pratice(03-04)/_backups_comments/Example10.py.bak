# Example10.py
# Topic: Using **kwargs for Variable Keyword Arguments

# This file demonstrates how to use **kwargs to create functions that can
# accept any number of keyword arguments, collected into a dictionary.


# Prints all keyword arguments as key-value pairs
def print_info(**kwargs) -> None:
    for key, value in kwargs.items():
        print(key + ": " + str(value))

print_info(name="Alice", age=25)
print_info(city="NYC", country="USA")


# Creates a user profile from keyword arguments
def create_profile(**info) -> dict:
    return info

profile = create_profile(name="John", age=30, city="LA")
print("Profile: " + str(profile))


# Prints formatted user information
def print_user(**user_data) -> None:
    print("=== User Info ===")
    if "name" in user_data:
        print("Name: " + user_data["name"])
    if "age" in user_data:
        print("Age: " + str(user_data["age"]))
    if "email" in user_data:
        print("Email: " + user_data["email"])

print_user(name="Alice", email="alice@example.com")
print_user(name="Bob", age=25, city="Chicago")


# Counts how many keyword arguments were passed
def count_kwargs(**kwargs) -> int:
    return len(kwargs)

count = count_kwargs(a=1, b=2, c=3)
print("Count: " + str(count))


# Returns specific value from kwargs or a default
def get_value(key, **kwargs) -> str:
    if key in kwargs:
        return kwargs[key]
    return "Not found"

value = get_value("name", name="Alice", age=25)
print("Value: " + value)

value2 = get_value("country", name="Alice")
print("Value: " + value2)


# Builds a configuration dictionary
def build_config(**config) -> dict:
    defaults = {"debug": False, "version": "1.0", "port": 8080}
    for key, value in config.items():
        defaults[key] = value
    return defaults

config = build_config(debug=True, port=3000)
print("Config: " + str(config))


# Validates that all required keys are present
def validate(required_keys, **kwargs) -> bool:
    for key in required_keys:
        if key not in kwargs:
            return False
    return True

result = validate(["name", "email"], name="Alice", email="a@b.com")
print("Valid: " + str(result))

result2 = validate(["name", "age"], name="Bob")
print("Valid: " + str(result2))


# Updates a dictionary with additional fields
def update_record(base_record, **updates) -> dict:
    record = base_record.copy()
    for key, value in updates.items():
        record[key] = value
    return record

original = {"id": 1, "name": "Alice"}
updated = update_record(original, age=25, city="NYC")
print("Updated: " + str(updated))


# Formats a URL query string from kwargs
def build_query(**params) -> str:
    query_parts = []
    for key, value in params.items():
        query_parts.append(key + "=" + str(value))
    return "?" + "&".join(query_parts)

query = build_query(search="python", page=1, limit=10)
print("Query: " + query)


# Converts all values to strings for display
def display_all(**kwargs) -> None:
    for key, value in kwargs.items():
        print(key + " = " + str(value))

display_all(count=5, active=True, rate=3.14)


# Collects database connection parameters
def connect_db(**db_params) -> str:
    host = db_params.get("host", "localhost")
    port = db_params.get("port", 5432)
    database = db_params.get("database", "mydb")
    return database + " at " + host + ":" + str(port)

conn = connect_db(host="db.example.com", database="users")
print("Connection: " + conn)
