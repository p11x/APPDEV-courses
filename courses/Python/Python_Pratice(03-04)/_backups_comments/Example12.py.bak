# Example12.py
# Topic: Positional-Only Parameters (/)

# This file demonstrates positional-only parameters in Python 3.8+.
# Parameters before / must be passed by position, not by keyword.


# Simple function with positional-only parameters
def pos_only(a, b, /, c) -> None:
    print("a=" + str(a) + ", b=" + str(b) + ", c=" + str(c))

pos_only(1, 2, 3)
pos_only(1, 2, c=3)


# Parameters before / cannot be passed as keywords
def create_user(name, /, age, city) -> None:
    print("Name: " + name + ", Age: " + str(age) + ", City: " + city)

create_user("Alice", 25, "NYC")
create_user("Bob", city="LA", age=30)


# All parameters can be positional-only
def add_all(a, b, c, /) -> int:
    return a + b + c

result = add_all(1, 2, 3)
print("Sum: " + str(result))


# Mix positional-only with regular parameters
def calculate(a, b, /, operation, multiplier=1) -> int:
    if operation == "add":
        result = a + b
    else:
        result = a * b
    return result * multiplier

result = calculate(5, 3, operation="add")
print("Result: " + str(result))

result2 = calculate(5, 3, operation="multiply", multiplier=2)
print("Result: " + str(result2))


# Positional-only with defaults
def greet(name, /, greeting="Hello") -> None:
    print(greeting + ", " + name + "!")

greet("Alice")
greet("Bob", "Hi")


# Function that mimics str.replace
def replace_text(text, old, new, /, count=-1) -> str:
    return text.replace(old, new, count)

result = replace_text("hello world", "world", "Python")
print("Result: " + result)

result2 = replace_text("aaa aaa", "a", "b", 2)
print("Result: " + result2)


# Positional-only for API-like functions
def fetch(url, /, method="GET", headers=None) -> None:
    print("URL: " + url)
    print("Method: " + method)
    if headers:
        print("Headers: " + str(headers))

fetch("https://api.example.com")
fetch("https://api.example.com", "POST")
fetch("https://api.example.com", headers={"Auth": "token"})


# Using with *args
def func_with_args(a, b, /, *args, keyword_arg) -> None:
    print("a=" + str(a) + ", b=" + str(b))
    print("args=" + str(args))
    print("keyword_arg=" + str(keyword_arg))

func_with_args(1, 2, 3, 4, 5, keyword_arg="value")


# Complex example: math operations
def math_op(x, y, /, op="add", precision=2) -> float:
    if op == "add":
        result = x + y
    elif op == "subtract":
        result = x - y
    elif op == "multiply":
        result = x * y
    elif op == "divide":
        result = x / y
    else:
        result = 0
    
    return round(result, precision)

result = math_op(10, 5, op="add")
print("Result: " + str(result))

result2 = math_op(10, 5, op="divide", precision=3)
print("Result: " + str(result2))


# Positional-only for performance-critical code
def process_pixels(width, height, /, channels=3) -> None:
    total = width * height * channels
    print("Processing " + str(total) + " pixels")

process_pixels(1920, 1080)
process_pixels(1920, 1080, channels=4)


# Prevent keyword arguments for function signature clarity
def send_message(sender, recipient, /, subject="", body="") -> None:
    print("From: " + sender)
    print("To: " + recipient)
    print("Subject: " + subject)
    print("Body: " + body)

send_message("alice@example.com", "bob@example.com", body="Hello!")
