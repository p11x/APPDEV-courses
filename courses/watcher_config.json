{
    "watched_directory": ".",
    "debounce_seconds": 3,
    "ignored_patterns": [
        ".git",
        "__pycache__",
        "*.pyc",
        ".DS_Store",
        "auto_commit.log"
    ],
    "branch": "master",
    "auto_push": true,
    "commit_message_format": "Auto-commit: {event} - {filename} - {timestamp}"
}
